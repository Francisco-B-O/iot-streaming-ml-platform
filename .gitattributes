# Auto-detect text files and normalize line endings
* text=auto

# Java
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf

# Python
*.py text eol=lf

# TypeScript / JavaScript
*.ts text eol=lf
*.js text eol=lf
*.json text eol=lf
*.css text eol=lf
*.html text eol=lf

# Shell scripts
*.sh text eol=lf

# Docs
*.md text eol=lf

# Docker
Dockerfile text eol=lf
*.conf text eol=lf

# Binary
*.joblib binary
*.parquet binary
*.jar binary
*.class binary
