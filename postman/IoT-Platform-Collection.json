                                "value": "application/json"
                            },
                            {
                                "key": "Authorization",
                                "value": "Bearer {{token}}"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Sensor A\",\n  \"type\": \"temperature\",\n  \"location\": \"Madrid\",\n  \"description\": \"Temperature sensor in main warehouse\",\n  \"serialNumber\": \"SNS-2026-001\",\n  \"status\": \"ACTIVE\"\n}"
