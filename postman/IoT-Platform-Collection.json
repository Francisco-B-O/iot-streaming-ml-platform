                                    "value": "24h"
                                },
                                {
                                    "key": "metrics",
                                    "value": "temperature,humidity,anomalies"
                                }
                            ]
                        },
                        "description": "Get analytics for a specific device\n\n**Authorization:** Bearer Token required\n\n**Path Parameter:**\n- deviceId: UUID of the device\n\n**Query Parameters:**\n- timeRange: time period (1h | 24h | 7d | 30d)\n- metrics: comma-separated metric names\n\n**Response (200):**\n```json\n{\n  \"deviceId\": \"device-uuid-1\",\n  \"timeRange\": \"24h\",\n  \"data\": {\n    \"temperature\": {\n      \"avg\": 24.5,\n      \"min\": 18.2,\n      \"max\": 32.8,\n      \"std\": 3.2,\n      \"dataPoints\": 1440\n    },\n    \"humidity\": {\n      \"avg\": 58.3,\n      \"min\": 35,\n      \"max\": 75\n    },\n    \"anomalies\": {\n      \"count\": 2,\n      \"timestamps\": [\"2026-03-31T08:15:00Z\", \"2026-03-31T14:30:00Z\"]\n    }\n  }\n}\n```"
